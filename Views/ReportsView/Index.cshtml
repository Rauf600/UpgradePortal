@{
    Layout = "_Layout";
}

<h2>Reports</h2>

<div class="dashboard-grid">

    <div class="card">
        <h3>@ViewBag.TotalSchedules</h3>
        <p>Total Schedules</p>
    </div>

    <div class="card">
        <h3>@ViewBag.PendingSchedules</h3>
        <p>Pending Schedules</p>
    </div>

    <div class="card">
        <h3>@ViewBag.CompletedSchedules</h3>
        <p>Completed Schedules</p>
    </div>

    <div class="card">
        <h3>@ViewBag.CancelledSchedules</h3>
        <p>Cancelled Schedules</p>
    </div>

</div>

<br />

<div class="dashboard-grid">

    <div class="card">
        <h3>@ViewBag.TotalShellRequests</h3>
        <p>Total Shell Requests</p>
    </div>

    <div class="card">
        <h3>@ViewBag.PendingShellRequests</h3>
        <p>Pending Shell Requests</p>
    </div>

    <div class="card">
        <h3>@ViewBag.CompletedShellRequests</h3>
        <p>Completed Shell Requests</p>
    </div>

    <div class="card">
        <h3>@ViewBag.CancelledShellRequests</h3>
        <p>Cancelled Shell Requests</p>
    </div>

</div>