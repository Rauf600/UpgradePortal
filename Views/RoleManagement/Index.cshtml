@model List<UpgradePortal.Web.Models.Role>
@{
    Layout = "_Layout";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
    <h2>Role Management</h2>
    <a href="/RoleManagement/Create" class="btn btn-primary">+ Add Custom Role</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="text-danger" style="margin-bottom:12px;">
        @TempData["Error"]
    </div>
}

<table class="portal-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Role Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var role in Model)
            {
                <tr>
                    <td>@role.RoleId</td>
                    <td>@role.RoleName</td>
                    <td>@role.Description</td>

                    <td>
                        <div class="action-row">

                            <a href="/RoleManagement/Edit/@role.RoleId"
                                   class="btn btn-primary btn-sm">
                                Edit
                            </a>

                            <form method="post"
                                  action="/RoleManagement/Delete/@role.RoleId"
                                  class="delete-role-form">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-danger btn-sm">
                                    Delete
                                </button>
                            </form>

                        </div>
                    </td>

                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4">No roles found.</td>
            </tr>
        }

    </tbody>
</table>
<!-- DELETE MODAL -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content">

        <h3>Delete Role</h3>

        <p>
            Are you sure you want to delete this role?
        </p>

        <div class="modal-actions">
            <button id="confirmDeleteBtn" class="btn btn-danger">
                Delete
            </button>

            <button id="cancelDeleteBtn" class="btn btn-info">
                Cancel
            </button>
        </div>

    </div>
</div>

<script>
    let currentDeleteForm = null;

    const modal = document.getElementById("deleteModal");
    const confirmBtn = document.getElementById("confirmDeleteBtn");
    const cancelBtn = document.getElementById("cancelDeleteBtn");

    document.querySelectorAll(".delete-role-form").forEach(form => {

        form.addEventListener("submit", function (e) {
            e.preventDefault();

            currentDeleteForm = form;

            modal.classList.add("show-modal");
        });

    });

    confirmBtn.addEventListener("click", function () {

        if (currentDeleteForm) {
            currentDeleteForm.submit();
        }

    });

    cancelBtn.addEventListener("click", function () {
        modal.classList.remove("show-modal");
    });

    window.addEventListener("click", function (e) {

        if (e.target === modal) {
            modal.classList.remove("show-modal");
        }

    });
</script>