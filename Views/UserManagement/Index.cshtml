@model List<UpgradePortal.Web.Models.User>
@{
    Layout = "_Layout";
}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
    <h2>User Management</h2>
    <a href="/UserManagement/Create" class="btn btn-primary">+ Add New User</a>
</div>

<table class="portal-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>2FA</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.Role?.RoleName</td>
                    <td>@(user.TwoFactorEnabled ? "Enabled" : "Disabled")</td>

                    <td>
                        @if (user.IsActive)
                        {
                            <span class="status-badge status-completed">Active</span>
                        }
                        else
                        {
                            <span class="status-badge status-cancelled">Inactive</span>
                        }
                    </td>

                    <td>
                        <div class="action-row">

                            @if (user.IsActive)
                            {
                                <form method="post" action="/UserManagement/Deactivate/@user.UserId">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-warning btn-sm">Deactivate</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="/UserManagement/Activate/@user.UserId">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-success btn-sm">Activate</button>
                                </form>
                            }

                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7">No users found.</td>
            </tr>
        }
    </tbody>
</table>