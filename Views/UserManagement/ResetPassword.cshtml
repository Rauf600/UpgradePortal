@model UpgradePortal.Web.ViewModels.UserResetPasswordViewModel
@{
    Layout = "_Layout";
}

<h2>Reset Password</h2>

<form method="post" action="/UserManagement/ResetPassword" class="form-card">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="UserId" />

    <div class="form-grid">
        <div>
            <label>User</label>
            <input asp-for="FullName" class="form-control" readonly />
        </div>

        <div>
            <label>New Password</label>
            <input asp-for="NewPassword" type="password" class="form-control" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <div>
            <label>Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Reset Password</button>
    <a href="/UserManagement" class="btn btn-info">Cancel</a>
</form>