@model List<UpgradePortal.Web.Models.ShellRequest>
@{
    Layout = "_Layout";

    string currentField = ViewBag.SortField as string ?? "date";
    string currentOrder = ViewBag.SortOrder as string ?? "asc";

    string NextOrder(string field)
    {
        return currentField == field && currentOrder == "asc" ? "desc" : "asc";
    }

    string Arrow(string field)
    {
        if (currentField != field) return "";
        return currentOrder == "asc" ? " ▲" : " ▼";
    }
}

<div class="page-header">
    <h2>Shell Requests</h2>

    <div class="header-actions">
        <a href="/ShellRequests/Create" class="btn btn-primary">+ New Shell Request</a>
    </div>
</div>

<table class="portal-table">
    <thead>
        <tr>
            <th>ID</th>

            <th>
                <a class="sort-link" href="@Url.Action("Index", new { sortField = "customer", sortOrder = NextOrder("customer") })">
                    Customer Name@(Arrow("customer"))
                </a>
            </th>

            <th>Customer Code</th>

            <th>
                <a class="sort-link" href="@Url.Action("Index", new { sortField = "clinic", sortOrder = NextOrder("clinic") })">
                    Clinic Name@(Arrow("clinic"))
                </a>
            </th>

            <th>Profile Version</th>

            <th>
                <a class="sort-link" href="@Url.Action("Index", new { sortField = "date", sortOrder = NextOrder("date") })">
                    Expected Date@(Arrow("date"))
                </a>
            </th>

            <th>Client Registry</th>

            <th>Submitted By</th>

            <th>
                <a class="sort-link" href="@Url.Action("Index", new { sortField = "status", sortOrder = NextOrder("status") })">
                    Status@(Arrow("status"))
                </a>
            </th>

            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.ShellRequestId</td>
                    <td>@item.Customer?.CustomerName</td>
                    <td>@item.Customer?.CustomerCode</td>
                    <td>@item.ClinicName</td>
                    <td>@item.ProfileVersion</td>
                    <td>@item.ExpectedDate?.ToString("yyyy-MM-dd")</td>
                    <td>@item.ClientRegistry</td>
                    <td>@item.CreatedByUser?.FullName</td>

                    <td>
                        <span class="status-badge status-@item.Status">
                            @item.Status
                        </span>
                    </td>

                    <td>
                        <div class="action-row">

                            <a href="/ShellRequests/Details/@item.ShellRequestId" class="btn btn-info btn-sm">View</a>

                            @if (item.Status == "pending")
                            {
                                <form method="post" action="/ShellRequests/Complete/@item.ShellRequestId">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm">Complete</button>
                                </form>

                                <form method="post" action="/ShellRequests/Cancel/@item.ShellRequestId">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-warning btn-sm">Cancel</button>
                                </form>
                            }
                            else
                            {
                                <span class="no-actions">No actions</span>
                            }

                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="10">No shell requests found.</td>
            </tr>
        }
    </tbody>
</table>