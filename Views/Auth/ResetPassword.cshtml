@model UpgradePortal.Web.ViewModels.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reset Password</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">

    <div class="login-container">
        <div class="login-card">

            <div class="login-header">
                <div class="login-logo-circle">EMR</div>
                <h1>Reset Password</h1>
                <p>Enter the code sent to your email and set a new password</p>
            </div>

            <form method="post" action="/Auth/ResetPassword">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Email" />

                <div class="login-field">
                    <label>Email</label>
                    <input asp-for="Email" class="login-input" readonly />
                </div>

                <div class="login-field">
                    <label>Verification Code</label>
                    <input asp-for="Code" class="login-input" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                <div class="login-field">
                    <label>New Password</label>
                    <input asp-for="NewPassword" type="password" class="login-input" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="login-field">
                    <label>Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="login-input" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="login-button">Reset Password</button>

                @if (ViewBag.Error != null)
                {
                    <div class="text-danger">@ViewBag.Error</div>
                }
            </form>

        </div>
    </div>

</body>
</html>