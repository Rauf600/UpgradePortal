@model UpgradePortal.Web.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Upgrade Portal</title>

    <style>
            html, body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                font-family: Arial, sans-serif;
                background: linear-gradient(135deg, #dbeafe, #eff6ff);
            }

            .login-page {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .login-card {
                width: 440px;
                background: #ffffff;
                padding: 36px;
                border-radius: 18px;
                box-shadow: 0 15px 40px rgba(0,0,0,.15);
            }

            .login-header {
                text-align: center;
                margin-bottom: 28px;
            }

            .login-logo-circle {
                width: 76px;
                height: 76px;
                margin: 0 auto 14px;
                background: #2563eb;
                color: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
                font-size: 20px;
            }

            .login-header h1 {
                margin: 0;
                font-size: 30px;
                color: #111827;
                line-height: 1.3;
                text-align: center;
            }

            .login-header p {
                margin-top: 10px;
                color: #64748b;
                text-align: center;
            }

            .login-field {
                margin-bottom: 16px;
            }

                .login-field label {
                    display: block;
                    margin-bottom: 6px;
                    font-weight: 600;
                }

            .login-input {
                width: 100%;
                padding: 12px;
                border: 1px solid #cbd5e1;
                border-radius: 8px;
                box-sizing: border-box;
                font-size: 14px;
            }

                .login-input:focus {
                    outline: none;
                    border-color: #2563eb;
                    box-shadow: 0 0 0 3px rgba(37,99,235,.15);
                }

            .login-button {
                width: 100%;
                padding: 12px;
                margin-top: 12px;
                background: #2563eb;
                color: white;
                border: none;
                border-radius: 8px;
                font-weight: 600;
                cursor: pointer;
                font-size: 15px;
            }

                .login-button:hover {
                    background: #1d4ed8;
                }

            .forgot-password {
                margin-top: 14px;
                text-align: center;
            }

                .forgot-password a {
                    color: #2563eb;
                    text-decoration: none;
                    font-weight: 600;
                    font-size: 14px;
                }

                    .forgot-password a:hover {
                        text-decoration: underline;
                    }

            .text-danger {
                color: #dc2626;
                margin-top: 12px;
                text-align: center;
            }
    </style>
</head>

<body>

    <div class="login-page">
        <div class="login-card">

            <div class="login-header">
                <div class="login-logo-circle">EMR</div>

                <h1>
                    Upgrade and New shell <br />
                    Request Portal
                </h1>

                <p>Sign in to continue</p>
            </div>

            <form asp-controller="Auth"
                  asp-action="Login"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="login-field">
                    <label>Email</label>

                    <input asp-for="Email"
                           class="login-input" />
                </div>

                <div class="login-field">
                    <label>Password</label>

                    <input asp-for="Password"
                           type="password"
                           class="login-input" />
                </div>

                <button type="submit"
                        class="login-button">
                    Login
                </button>

                <div class="forgot-password">
                    <a href="/Auth/ForgotPassword">
                        Forgot Password?
                    </a>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="text-danger">
                        @ViewBag.Error
                    </div>
                }
            </form>

        </div>
    </div>

</body>
</html>