@model UpgradePortal.Web.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Forgot Password</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page">

    <div class="login-container">
        <div class="login-card">

            <div class="login-header">
                <div class="login-logo-circle">EMR</div>
                <h1>Forgot Password</h1>
                <p>Enter your email to receive a reset code</p>
            </div>

            <form method="post" action="/Auth/ForgotPassword">
                @Html.AntiForgeryToken()

                <div class="login-field">
                    <label>Email</label>
                    <input asp-for="Email" class="login-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="login-button">Send Reset Code</button>

                @if (ViewBag.Error != null)
                {
                    <div class="text-danger">@ViewBag.Error</div>
                }

                @if (ViewBag.Message != null)
                {
                    <div style="margin-top:12px; color:green;">@ViewBag.Message</div>
                }
            </form>

        </div>
    </div>

</body>
</html>